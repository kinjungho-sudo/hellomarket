        "url": "https://api.resend.com/emails",
        "authentication": "none",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "Bearer re_DEffwJed_BWjB3Hb3GMT136tEJWYbSwuY"
            },
