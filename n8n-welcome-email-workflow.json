        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ from: 'Hello Garden Market <kinjungho@gmail.com>', to: [$json.to], subject: $json.subject, html: $json.html }) }}",
        "options": {}
      },
      "id": "send-resend",
      "name": "Resend 이메일 발송",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
