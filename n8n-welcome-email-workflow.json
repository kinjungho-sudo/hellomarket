        "respondWith": "json",
        "responseBody": "={\n  \"success\": true,\n  \"message\": \"환영 이메일 발송 완료\",\n  \"to\": \"{{ $('환영 이메일 HTML 생성').item.json.to }}\"\n}",
        "options": {
